{
  "name": "markethub-pakistan",
  "version": "1.0.0",
  "description": "MarketHub Pakistan - Online Marketplace Platform",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:next\" \"npm run dev:server\"",
    "dev:next": "next dev -p 3000",
    "dev:server": "nodemon server/index.js",
    "build": "next build",
    "start": "NODE_ENV=production node server/index.js",
    "lint": "next lint",
    "seed": "node server/utils/seed.js"
  },
  "dependencies": {
    "next": "^14.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "express": "^4.18.2",
    "mongoose": "^8.1.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cloudinary": "^2.0.1",
    "multer": "^1.4.5-lts.1",
    "express-rate-limit": "^7.1.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.7.4",
    "helmet": "^7.1.0",
    "express-validator": "^7.0.1",
    "slugify": "^1.6.6",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^5.0.1",
    "zustand": "^4.5.0",
    "dayjs": "^1.11.10",
    "sharp": "^0.33.2"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.1",
    "postcss": "^8.4.33",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.3",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.1.0"
